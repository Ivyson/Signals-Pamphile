      "y[0] = 3.0\n",
      "y[1] = 4.5\n",
      "y[2] = 5.25\n",
      "y[3] = 5.625\n"
     ]
    }
   ],
   "source": [
    "yn = 0\n",
    "for i in range(0, 4):\n",
    "    y = 3 + 0.5*yn\n",
    "    yn = y\n",
    "    print(f'y[{i}] = {y}')"
   ]
