    "import numpy as np\n",
    "\n",
    "x = np.array([0, -1, -1, -1, 0, 1, 2,3, 3, 1, 1, 0])\n",
    "\n",
    "h = np.array([ 0, 0 ,0 ,2, 3, 1, 0])\n",
    "y = np.convolve(h,x,mode=\"full\")\n",
    "# length of new convolution = len(x ) + len(h) - 1 = 12 + 6 = 18\n",
    "int(y[5])"
   ]
