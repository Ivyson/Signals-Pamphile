    "#  Define the actual function:\n",
    "#  y[n] = a*x[n]+(1-a)*y[n-1]\n",
    "# a = 0.05, x[n] = n\n",
    "a = 0.05\n",
    "yn = 0\n",
    "for i in range(0, 37):\n",
    "    y = a*i + (1-a)*yn\n",
    "    yn = y\n",
    "print(y)"
   ]
  }
